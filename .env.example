# Nanobot 环境变量配置

# ============================================
# 安全相关配置（必填）
# ============================================

# JWT 密钥 - 必须设置，至少 32 个字符
# 生产环境请使用随机生成的强密钥，如: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# JWT Token 有效期，默认 7 天
# 支持格式: 1h, 24h, 7d, 168h
JWT_TOKEN_DURATION=168h

# ============================================
# 数据库配置
# ============================================

# SQLite 日志级别，设置为 0 关闭详细日志
NANOBOT_DB_LOG=1

# ============================================
# 应用配置（可选）
# ============================================

# 应用工作目录
# NANOBOT_WORKSPACE=./data

# 日志级别: debug, info, warn, error
# LOG_LEVEL=info

